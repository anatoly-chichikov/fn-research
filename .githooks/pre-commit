#!/usr/bin/env bash
set -euo pipefail

repo="$(git rev-parse --show-toplevel)"
cache="${HOME}/.cargo/registry"
target="${repo}/target"
delta="$(git diff --name-only --cached)"
build=0
if ! docker image inspect research-lint >/dev/null 2>&1; then
  docker build -t research-lint -f - "${repo}" <<'DOCKERFILE'
FROM rust:bookworm
RUN rustup component add rustfmt clippy
WORKDIR /app
DOCKERFILE
fi
docker run --rm \
  -v "${repo}":/app \
  -v "${cache}":/usr/local/cargo/registry \
  -v "${target}":/app/target \
  -w /app research-lint \
  bash -c "cargo fmt --all -- --check && cargo clippy --workspace -- -D warnings"
if [ -z "${delta}" ]; then
  delta="$(git diff --name-only)"
fi
if ! docker image inspect research-test >/dev/null 2>&1; then
  build=1
elif echo "${delta}" | grep -E -q '^(Cargo\.|crates/|Dockerfile\.test)'; then
  build=1
fi
if [ "${build}" -eq 1 ]; then
  docker build -t research-test -f "${repo}/Dockerfile.test" "${repo}"
else
  echo "Skipping docker build because no relevant changes"
fi
docker run --rm research-test
